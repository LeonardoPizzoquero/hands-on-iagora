# Supabase — copie para .env.local e preencha com os valores do seu projeto.
# NUNCA commite .env.local nem valores reais.

# URL pública do projeto Supabase (pode ir ao client).
NEXT_PUBLIC_SUPABASE_URL=

# Publishable/anon key (pode ir ao client — a segurança vem do RLS, não de esconder a chave).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service role key — PODER TOTAL, ignora RLS.
# USO EXCLUSIVO NO SERVIDOR. NUNCA exponha ao client, NUNCA use prefixo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
